# cop/kkr were plain aliases in older versions of this file. Drop any stale alias so
# re-sourcing can (re)define them as functions instead of hitting a parse error.
unalias cop kkr 2>/dev/null

# Rubocop -a on Ruby files changed vs origin/master (function: evaluates the diff when run)
cop() {
  local -a files
  files=("${(@f)$(git diff --name-only --diff-filter=ACMR origin/master...HEAD -- '*.rb' '*.rake')}")
  if (( ${#files[@]} == 0 )); then
    echo "No changed Ruby files vs origin/master"
    return 0
  fi
  ./bin/rubocop -a "${files[@]}"
}

# Kill whatever is listening on a port (default 3000). Function so the PIDs are resolved when run.
kkr() {
  local port="${1:-3000}"
  local -a pids
  pids=(${(f)"$(lsof -t -i:"$port" -sTCP:LISTEN)"})
  if (( ${#pids} == 0 )); then
    echo "Nothing listening on :$port"
    return 0
  fi
  kill -9 "${pids[@]}"
}


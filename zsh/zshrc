# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git)

# Docker CLI completions (must be on fpath before compinit runs in oh-my-zsh)
fpath=($HOME/.docker/completions $fpath)

source $ZSH/oh-my-zsh.sh

# Login shells read ~/.zprofile (rbenv, Homebrew). Cursor and many tools use a
# non-login interactive zsh, so ensure the same PATH/Ruby here too.
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
command -v rbenv &>/dev/null && eval "$(rbenv init - --no-rehash zsh)"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Editor
alias vim=nvim
export MANPAGER="nvim +Man!"

# Secrets (tokens, etc.) — keep the file chmod 600 and out of git
[ -f "$HOME/.zsh_secrets" ] && source "$HOME/.zsh_secrets"

[ -f ~/.aliases ] && source ~/.aliases

export PATH="/Applications/Docker.app/Contents/Resources/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export TESSDATA_PREFIX=/opt/homebrew/share/tessdata

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# tmuxinator completions
_tmux_zsh=$(gem contents tmuxinator 2>/dev/null | grep 'tmuxinator\.zsh$')
[[ -f "$_tmux_zsh" ]] && source "$_tmux_zsh"
unset _tmux_zsh

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

# Claude Code without permission prompts
yolo() {
  claude --dangerously-skip-permissions "$@"
}

# Machine-local config (not tracked) — work env, host-specific PATH, extras
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
